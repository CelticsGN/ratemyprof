# Backend Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit the actual .env file!

# Supabase Configuration (REQUIRED)
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Configuration (REQUIRED - Generate random 64-char string)
JWT_SECRET_KEY=generate-a-random-64-character-string-here-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin Credentials (REQUIRED)
# Run: python scripts/generate_admin_hash.py "YourSecureP@ssw0rd!"
# Then paste the generated hash below
ADMIN_USERNAME=admin@ratemyprof.in
ADMIN_PASSWORD_HASH=$bcrypt$paste-hash-from-generate-script-here

# CORS Configuration (REQUIRED)
ALLOWED_ORIGINS=https://ratemyprof.me,https://www.ratemyprof.me,http://localhost:3000

# Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15

# API Documentation (Development only - set to false in production)
DOCS_ENABLED=false
DOCS_ACCESS_TOKEN=random-token-for-docs-access

# Environment
ENVIRONMENT=development
