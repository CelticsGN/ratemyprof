// Prisma schema for metrics database
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Metric {
  id         Int      @id @default(autoincrement())
  eventType  String   @map("event_type")
  data       String?  // JSON string
  timestamp  DateTime @default(now())

  @@index([eventType])
  @@index([timestamp])
  @@map("metrics")
}
